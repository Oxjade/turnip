# ============================================================
# Turnip VPN — Payment Backend Config
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Lemon Squeezy ─────────────────────────────────────────────
# Webhook signing secret: LS Dashboard → Settings → Webhooks → Secret
LEMONSQUEEZY_WEBHOOK_SECRET=your-signing-secret-here

# Checkout URLs for each plan variant (LS Dashboard → Products → Variants → Share)
# These are pre-created in your Lemon Squeezy store.
LEMONSQUEEZY_BASIC_VARIANT_URL=https://your-store.lemonsqueezy.com/buy/BASIC-VARIANT-UUID
LEMONSQUEEZY_PRO_VARIANT_URL=https://your-store.lemonsqueezy.com/buy/PRO-VARIANT-UUID
LEMONSQUEEZY_BUSINESS_VARIANT_URL=https://your-store.lemonsqueezy.com/buy/BUSINESS-VARIANT-UUID

# ── VPN server ──────────────────────────────────────────────
VPN_SERVER_ADDR=vpn.yourdomain.com
MAX_USERS=80

# Paths (defaults work if install.sh was used)
IPSEC_SECRETS_FILE=/etc/ipsec.secrets
CA_CERT_PATH=/etc/ipsec.d/cacerts/caCert.pem

# ── Database ─────────────────────────────────────────────────
DB_PATH=/opt/securefastvpn/payments.db

# ── Email ────────────────────────────────────────────────────
# Choose: smtp | sendgrid | resend
EMAIL_PROVIDER=smtp

FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=SecureFast VPN

# SMTP (Gmail example — use an App Password, not your main password)
# Gmail app passwords: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password-here

# SendGrid (alternative — leave blank if using SMTP)
SENDGRID_API_KEY=

# Resend (alternative — FROM_EMAIL must be on a verified domain)
RESEND_API_KEY=

# ── Admin Panel ───────────────────────────────────────────────
# Secret token for the admin API at port 8765. Set a strong random value.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=your-strong-random-admin-token-here

# ── Crypto Payments (NOWPayments) ─────────────────────────────
# Sign up at: https://nowpayments.io — free account, no monthly fee
# API key: NOWPayments dashboard → Store Settings → API Keys
NOWPAYMENTS_API_KEY=your-nowpayments-api-key-here
# IPN secret: NOWPayments dashboard → Store Settings → IPN Secret
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret-here
# Approx NGN/USD rate used to convert plan prices to USD for invoice creation
# Update periodically or integrate a live rate API
NGN_TO_USD_RATE=1600
# Full public URL of your site (used in IPN callback and redirect URLs)
SITE_URL=https://yourdomain.com
